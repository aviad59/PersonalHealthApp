# Anthropic
ANTHROPIC_API_KEY=

# Hevy
HEVY_API_KEY=

# Turso (libSQL) — required
# Create one with the Turso CLI:
#   turso db create health-dashboard
#   turso db show health-dashboard --url
#   turso db tokens create health-dashboard
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=
