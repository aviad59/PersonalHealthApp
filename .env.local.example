# Required
ANTHROPIC_API_KEY=sk-ant-...
HEVY_API_KEY=your-hevy-api-key
# Per-user Hevy keys for other workouts-enabled users (optional; each user
# needs their OWN key so workouts don't collide). Workouts UI shows without
# a key, but Hevy sync stays empty until the matching key is set.
HEVY_API_KEY_ERAN=
HEVY_API_KEY_DAN=

# Auth (Google sign-in via NextAuth)
# Create an OAuth Client ID (type "Web application") in Google Cloud Console
# > APIs & Services > Credentials. Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google        (dev)
#   https://<your-prod-domain>/api/auth/callback/google   (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Required in production; the canonical URL of the deployed app.
NEXTAUTH_URL=http://localhost:3000

# Database (Turso / libSQL)
# Create with the Turso CLI:
#   turso db create health-dashboard
#   turso db show health-dashboard --url    # paste below
#   turso db tokens create health-dashboard # paste below
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=

# Photo storage (Vercel Blob)
# Vercel dashboard > Storage > Create Database > Blob, then connect it to
# this project. In prod the token is injected automatically; for local dev,
# `vercel env pull .env.local` or copy the token from the Blob store settings.
BLOB_READ_WRITE_TOKEN=

# Web Push notifications + daily-insight cron
# Generate once: npx web-push generate-vapid-keys
# Add VAPID_PUBLIC_KEY + VAPID_PRIVATE_KEY + VAPID_SUBJECT to Vercel
# (Production env), and ALSO add the public key a second time as
# NEXT_PUBLIC_VAPID_PUBLIC_KEY so the browser can subscribe.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Random secret — Vercel sends this in the Authorization header on cron runs.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional (scaffold only — not used yet)
ZEPP_API_KEY=
